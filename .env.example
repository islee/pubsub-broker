# pubsub-broker configuration — copy to `.env` and edit for local development.
#
# Precedence: real process environment > .env file > built-in defaults.
# Secrets: any BROKER_X below also accepts BROKER_X_FILE pointing at a file whose contents are the
# value (Docker/Render secret mounts, key-file credentials). The env var wins if both are set.
# Only this template is committed; all other .env* files are git-ignored.

# ── storage / retention (DESIGN.md §§4–5) ──────────────────────────────────────────────
BROKER_DB_PATH=/tmp/broker.db          # SQLite cache path (ephemeral on Render free tier)
BROKER_BUDGET_BYTES=52428800           # cache byte ceiling B (~50MB)
BROKER_MIN_RETAIN=16                   # mandatory per-topic floor (last K), gated by a live subscriber
BROKER_QUEUE_MAXSIZE=256               # bounded live queue per subscriber

# ── external durable store (DESIGN.md §§4.3, 6) ────────────────────────────────────────
BROKER_PERSIST_BACKEND=none            # none | postgres | kv
# BROKER_PERSIST_DSN=postgresql://user:pass@host:5432/broker   # or BROKER_PERSIST_DSN_FILE=/run/secrets/dsn
BROKER_SYNC_BATCH_SIZE=256
BROKER_SYNC_BREAKER_THRESHOLD=5

# ── transports (DESIGN.md §7) ──────────────────────────────────────────────────────────
BROKER_TRANSPORTS=sse,longpoll,webhook # subset of: sse,longpoll,webhook (websocket deferred)

# ── per-topic publish rate limit (DESIGN.md §5.3) ──────────────────────────────────────
BROKER_RATELIMIT_CAPACITY=10           # burst tokens per topic
BROKER_RATELIMIT_REFILL_PER_SEC=10     # sustained refill rate per topic
BROKER_RATELIMIT_MAX_TOPICS=10000      # LRU bound on tracked buckets

# ── auth (DESIGN.md §8) ────────────────────────────────────────────────────────────────
BROKER_AUTH_BACKEND=oauth              # oauth | api_key | none
# OAuth: enable one or more JWKS providers; a token is matched to one by its `iss` claim.
BROKER_OAUTH_PROVIDERS=                # subset of: supabase,cloudflare_access,auth0,okta,google
BROKER_OAUTH_SVC_SCOPE=broker:svc      # scope/claim that grants the svc role (Auth0/Okta)
# BROKER_OAUTH_SVC_PRINCIPALS=svc-account-sub,ops@example.com   # subject allowlist → svc (CF Access/Google)

# -- Supabase Auth --
# BROKER_SUPABASE_PROJECT_REF=abcdefghijklmnop

# -- Cloudflare Access --
# BROKER_CF_ACCESS_TEAM_DOMAIN=myteam            # -> https://myteam.cloudflareaccess.com
# BROKER_CF_ACCESS_AUD=<access-application-AUD-tag>

# -- Auth0 --
# BROKER_AUTH0_DOMAIN=acme.us.auth0.com
# BROKER_AUTH0_AUDIENCE=https://api.broker.example

# -- Okta --
# BROKER_OKTA_DOMAIN=dev-123456.okta.com
# BROKER_OKTA_AUTH_SERVER=default
# BROKER_OKTA_AUDIENCE=api://broker

# -- Google (validates ID tokens) --
# BROKER_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# api_key backend (dev / service-to-service): "svc:<key>,user:<key>"  (or BROKER_API_KEYS_FILE)
# BROKER_API_KEYS=

# ── webhook delivery (DESIGN.md §7) ────────────────────────────────────────────────────
BROKER_WEBHOOK_MAX_ATTEMPTS=5
BROKER_WEBHOOK_BREAKER_THRESHOLD=10
# BROKER_WEBHOOK_HMAC_SECRET=<random-32+-bytes>   # or BROKER_WEBHOOK_HMAC_SECRET_FILE=/run/secrets/hmac
